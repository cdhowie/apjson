from typing import Any, Callable, Optional, Union, bool, bytes, str

def loads(json: Union[bytes, str], object_hook: Optional[Callable[[dict], Any]] = None) -> Any: ...

def dumps(value: Any, object_hook: Optional[Callable[[Any], Any]] = None, check_circular: bool = True) -> bytes: ...

class Fragment:
    def __init__(self, content: bytes, validate: bool = True) -> None: ...
